---
const { img, pair } = Astro.props;
---

<div class="card js-card" id="responsiveboard" data-value={pair}>
    <div class="card-inner">
        <div class="card-front">
            <img
                src="/Dekoration/Frontside.png"
                alt="Dekoration Vorderseite"
                class="front-decoration"
            />
        </div>
        <div class="card-back">
            <img src={img} alt="memory card" />
        </div>
    </div>
</div>

<style>
    div {
        display: flex;
    }
    .card {
        perspective: 900px;
        cursor: pointer;
        width: 100%;
        aspect-ratio: 1;
        position: relative;
    }

    .card-inner {
        width: 100%;
        height: 100%;
        aspect-ratio: 1;
        transition: transform 0.6s;
        transform-style: preserve-3d;
        position: relative;
    }
    .card.flipped .card-inner {
        transform: rotateY(180deg);
    }
    .card-front {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #e98989;
        border-radius: 16px;
        backface-visibility: hidden;
    }
    .front-decoration {
        width: 100%;
        height: 100%;
        object-fit: contain;
        transform: scale(0.7);
    }

    .card-back {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        transform: rotateY(180deg);
        border-radius: 16px;
        backface-visibility: hidden;

        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden;
    }
    .card-back img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 16px;
        display: block;
    }
</style>
