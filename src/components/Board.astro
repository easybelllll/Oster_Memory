---
import Card from "./Card.astro";
const { size = 16 } = Astro.props;

// Bilderpfade aus /public
const allImages = [
  "/Eier/Eier1.png",
  "/Eier/Eier2.png",
  "/Eier/Eier3.png",
  "/Eier/Eier4.png",
  "/Hase/Hase1.png",
  "/Hase/Hase2.png",
  "/Hase/Karotten.png",
  "/Korb/Osterkorb1.png",
  "/Korb/Osterkorb2.png",
  "/Kueken/Kueken1.png",
  "/Kueken/Kueken2.png",
  "/Tulpen/Tulpen.png",
];

const pairCount = size / 2;

// Karten mischen
const shuffled = [...allImages].sort(() => Math.random() - 0.5);
const selected = shuffled.slice(0, pairCount);
const cards = [...selected, ...selected].sort(() => Math.random() - 0.5);

// Spalten für Grid
const columns = size === 24 ? 6 : 4;
---

<div
  class="board"
  data-paircount={pairCount}
  style={`grid-template-columns: repeat(${columns}, 1fr)`}
>
  {cards.map((card) => <Card img={card} pair={card} />)}
</div>

<style>
  .board {
    display: grid;
    padding: 20px;
    justify-content: center;
    background: white;
    flex: 1;
    margin: 0 auto;
    gap: 15px;
  }
</style>

<script define:vars={{ size }} is:inline>
  (() => {
    const board = document.querySelector(".board");
    if (!board) return;

    const pairCount = Number(board.dataset.paircount);
    let firstCard = null;
    let secondCard = null;
    let lock = false;
    let pairs = 0;

    let time = 0;
    let moves = 0;
    let timer = null;
    let firstClick = false;

    const timeEl = document.getElementById("time");
    const movesEl = document.getElementById("moves");

    function startTimer() {
      timer = setInterval(() => {
        time++;
        if (timeEl) timeEl.textContent = time;
      }, 1000);
    }

    function stopTimer() {
      if (timer) clearInterval(timer);
    }

    function flipCard(card) {
      if (
        lock ||
        card.classList.contains("flipped") ||
        card.classList.contains("matched")
      )
        return;

      if (!firstClick) {
        startTimer();
        firstClick = true;
      }

      card.classList.add("flipped");

      if (!firstCard) {
        firstCard = card;
        return;
      }

      secondCard = card;
      moves++;
      if (movesEl) movesEl.textContent = moves;

      if (firstCard.dataset.value === secondCard.dataset.value) {
        firstCard.classList.add("matched");
        secondCard.classList.add("matched");
        pairs++;
        resetTurn();

        if (pairs === pairCount) {
          stopTimer();

          const endUrl = new URL("/end", window.location.origin);
          endUrl.searchParams.set("time", time);
          endUrl.searchParams.set("moves", moves);
          endUrl.searchParams.set("cards", size);

          setTimeout(() => {
            window.location.href = endUrl.toString();
          }, 500);
        }
      } else {
        lock = true;
        setTimeout(() => {
          firstCard.classList.remove("flipped");
          secondCard.classList.remove("flipped");
          resetTurn();
        }, 700);
      }
    }

    function resetTurn() {
      firstCard = null;
      secondCard = null;
      lock = false;
    }

    board.querySelectorAll(".js-card").forEach((card) => {
      card.addEventListener("click", () => flipCard(card));
    });
  })();
</script>
