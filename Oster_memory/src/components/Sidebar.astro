---
const { links = [] } = Astro.props;
---

<aside class="sidebar">
  {links.map((link: { outline: any; action: any; value: any; text: unknown; }) => (
    <button
      class={link.outline ? 'btn-outline-pink' : 'btn'}
      onclick={link.action ? `window.${link.action}('${link.value ?? ''}')` : ''}
    >
      {link.text}
    </button>
  ))}
</aside>

<style>
.sidebar {
  display: flex;
  flex-direction: column;
  padding: 20px;
  background: #f8e88c;
  border-right: 1px solid #e0cfcf;
  min-width: 200px;
  height: 100vh;
  box-sizing: border-box;
}

.sidebar button {
  background: #e98989;
  border: none;
  color: white;
  padding: 12px 20px;
  margin-bottom: 12px;
  border-radius: 20px;
  cursor: pointer;
  font-size: 16px;
  transition: transform 0.2s;
}

.sidebar button:hover {
  transform: scale(1.05);
}

.btn-outline-pink {
  background: white;
  color: #e98989;
  border: 2px solid #e98989;
}
</style>