---
import LinkButton from "./LinkButton.astro";

const { links = [] } = Astro.props;
---

<aside class="sidebar">
  <!-- Top button(s) -->
  <div class="sidebar-buttons top">
    {
      links.map((link: { href: any; text: any; outline: any }) => (
        <LinkButton
          href={link.href ?? "#"}
          text={link.text}
          outline={link.outline}
        />
      ))
    }
  </div>

  <!-- Game info below -->
  <div class="game-info">
    <p>Zeit</p>
    <span id="time">0</span>
    <p>Züge</p>
    <span id="moves">0</span>
  </div>
</aside>

<script is:inline>
  let time = 0;
  let moves = 0;
  let timer = null;
  let timerRunning = false; // startet erst beim ersten Klick

  const timeEl = document.getElementById("time");
  const movesEl = document.getElementById("moves");

  // Timer starten
  export function startTimer() {
    if (!timerRunning) {
      timerRunning = true;
      timer = setInterval(() => {
        time++;
        timeEl.textContent = time;
      }, 1000);
    }
  }

  // Timer stoppen
  export function stopTimer() {
    clearInterval(timer);
  }

  // Move erhöhen
  export function incrementMoves() {
    moves++;
    movesEl.textContent = moves;
  }

  // Optional: Reset
  export function resetGameInfo() {
    time = 0;
    moves = 0;
    timerRunning = false;
    if (timer) clearInterval(timer);
    timeEl.textContent = time;
    movesEl.textContent = moves;
  }
</script>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 20px;
    background: #f8e88c;
    border-right: 1px solid #e0cfcf;
    min-width: 200px;
    height: 100vh;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
  }

  .sidebar-buttons.top,
  .game-info {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .game-info {
    text-align: center;
    font-size: 18px;
    margin-top: 30px;
  }

  .game-info span {
    display: block;
    font-size: 24px;
    margin-bottom: 8px;
    font-weight: bold;
  }
</style>
