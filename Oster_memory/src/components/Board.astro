---
import Card from "./Card.astro";
const { size = 16 } = Astro.props;

// Bilderpfade aus /public
const allImages = [
  "/Eier/Eier1.png",
  "/Eier/Eier2.png",
  "/Eier/Eier3.png",
  "/Eier/Eier4.png",
  "/Hase/Hase1.png",
  "/Hase/Hase2.png",
  "/Hase/Karotten.png",
  "/Korb/Osterkorb1.png",
  "/Korb/Osterkorb2.png",
  "/Kueken/Kueken1.png",
  "/Kueken/Kueken2.png",
  "/Tulpen/Tulpen.png",
];

const pairCount = size / 2;

// Karten mischen
const shuffled = [...allImages].sort(() => Math.random() - 0.5);
const selected = shuffled.slice(0, pairCount);
const cards = [...selected, ...selected].sort(() => Math.random() - 0.5);

// Spalten für Grid
const columns = size === 24 ? 6 : 4;
---

<div class="board" style={`grid-template-columns: repeat(${columns}, 1fr)`}>
  {cards.map((card) => <Card img={card} pair={card} />)}
</div>

<style>
  .board {
    display: grid;
    padding: 20px;
    justify-content: center;
    background: white;
    flex: 1;
    margin: 0 auto;
  }
</style>

<script is:inline>
  // Variablen
  let firstCard = null;
  let secondCard = null;
  let lock = false;

  let moves = 0;
  let time = 0;
  let pairs = 0;
  let timer;

  // Timer starten
  function startTimer() {
    timer = setInterval(() => {
      time++;
    }, 1000);
  }

  // Spiel beenden
  function endGame() {
    clearInterval(timer); // Timer stoppen
    localStorage.setItem("endTime", time); // Zeit speichern
    localStorage.setItem("endMoves", moves); // Züge speichern
    window.location.href = "/end"; // Endseite anzeigen
  }

  // Karten umdrehen
  function flipCard(card) {
    if (
      lock ||
      card.classList.contains("flipped") ||
      card.classList.contains("matched")
    )
      return;

    card.classList.add("flipped");

    if (!firstCard) {
      firstCard = card;
      return;
    }

    secondCard = card;
    moves++;

    if (firstCard.dataset.value === secondCard.dataset.value) {
      pairs++;
      firstCard.classList.add("matched");
      secondCard.classList.add("matched");
      resetTurn();

      // Prüfen, ob alle Paare gefunden wurden
      if (pairs === pairCount) {
        setTimeout(endGame, 500); // kleine Verzögerung für Animation
      }
    } else {
      lock = true;
      setTimeout(() => {
        firstCard.classList.remove("flipped");
        secondCard.classList.remove("flipped");
        resetTurn();
      }, 700);
    }
  }

  function resetTurn() {
    firstCard = null;
    secondCard = null;
    lock = false;
  }

  // Eventlistener setzen, sobald DOM fertig ist
  window.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".js-card").forEach((card) => {
      card.addEventListener("click", () => flipCard(card));
    });
  });

  // Timer starten
  startTimer();
</script>
