---
import Card from "./card.astro";
const { size = 16 } = Astro.props;

const allImages = [
  "../../public/Eier/Eier1.png",
  "../../public/Eier/Eier2.png",
  "../../public/Eier/Eier3.png",
  "../../public/Eier/Eier4.png",
  "../../public/Hase/Hase1.png",
  "../../public/Hase/Hase2.png",
  "../../public/Hase/Karotten.png",
  "../../public/Korb/Osterkorb1.png",
  "../../public/Korb/Osterkorb2.png",
  "../../public/Kueken/Kueken1.png",
  "../../public/Kueken/Kueken2.png",
  "../../public/Tulpen/Tulpen.png",
];

const pairCount = size / 2;
const shuffled = [...allImages].sort(() => Math.random() - 0.5);
const selected = shuffled.slice(0, pairCount);
const cards = [...selected, ...selected].sort(() => Math.random() - 0.5);

const columns = size === 24 ? 6 : 4;
---

<div
  class="board"
  style={`grid-template-columns: repeat(${columns}, 1fr)`}
  id="board"
>
  {cards.map((card) => <Card img={card} pair={card} />)}
</div>

<style>
  .board {
    display: grid;
    padding: 20px;
    justify-content: center;
    background: white;
    flex: 1;
    margin: 0 auto;
  }
</style>

<script is:inline>
  let firstCard = null;
  let secondCard = null;
  let lock = false;

  let moves = 0;
  let time = 0;
  let pairs = 0;
  let timer;

  const movesSpan = document.getElementById("moves"); // Züge
  const timeSpan = document.getElementById("time"); // Timer

  function startTimer() {
    timer = setInterval(() => {
      time++;
      if (timeSpan) timeSpan.textContent = time;
    }, 1000);
  }

  function flipCard(card) {
    if (
      lock ||
      card.classList.contains("flipped") ||
      card.classList.contains("matched")
    )
      return;

    card.classList.add("flipped");

    if (!firstCard) {
      firstCard = card;
      return;
    }

    secondCard = card;

    moves++;
    const movesSpan = document.getElementById("moves");
    if (movesSpan) movesSpan.textContent = moves;

    if (firstCard.dataset.value === secondCard.dataset.value) {
      pairs++;
      firstCard.classList.add("matched");
      secondCard.classList.add("matched");
      resetTurn();
    } else {
      lock = true;
      setTimeout(() => {
        firstCard.classList.remove("flipped");
        secondCard.classList.remove("flipped");
        resetTurn();
      }, 700);
    }
  }

  function resetTurn() {
    firstCard = null;
    secondCard = null;
    lock = false;
  }

  document
    .querySelectorAll(".js-card")
    .forEach((card) => card.addEventListener("click", () => flipCard(card)));

  startTimer();
</script>
