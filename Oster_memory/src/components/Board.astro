---
import Card from "./card.astro";
const { size = 16 } = Astro.props;

const allImages = [
  "/Eier/Eier1.png",
  "/Eier/Eier2.png",
  "/Eier/Eier3.png",
  "/Eier/Eier4.png",
  "/Hase/Hase1.png",
  "/Hase/Hase2.png",
  "/Hase/Karotten.png",
  "/Korb/Osterkorb1.png",
  "/Korb/Osterkorb2.png",
  "/Kueken/Kueken1.png",
  "/Kueken/Kueken2.png",
  "/Tulpen/Tulpen.png",
];

const pairCount = size / 2;
const shuffled = [...allImages].sort(() => Math.random() - 0.5);
const selected = shuffled.slice(0, pairCount);
const cards = [...selected, ...selected].sort(() => Math.random() - 0.5);

const columns = size === 24 ? 6 : 4;
---

<div
  class="board"
  style={`grid-template-columns: repeat(${columns}, 1fr)`}
  id="board"
>
  {cards.map((card) => <Card img={card} pair={card} />)}
</div>

<style>
  .board {
    display: grid;
    padding: 20px;
    justify-content: center;
    background: white;
    flex: 1;
    margin: 0 auto;
  }
</style>
