---
const { img } = Astro.props;
---

<div class="card js-card" data-value={img}>
    <div class="card-inner">
        <div class="card-front"></div>

        <div class="card-back">
            <img src={img} alt="memory card" />
        </div>
    </div>
</div>

<style>
    .card {
        perspective: 900px;
        cursor: pointer;
    }

    .card-inner {
        position: relative;
        width: 100px;
        aspect-ratio: 1;
        transition: transform 0.6s;
        transform-style: preserve-3d;
    }

    .card.flipped .card-inner {
        transform: rotateY(180deg);
    }

    .card-front,
    .card-back {
        position: absolute;
        width: 100%;
        height: 100%;
        border-radius: 16px;
        backface-visibility: hidden;
    }

    .card-front {
        background: #e98989;
    }

    .card-back {
        transform: rotateY(180deg);
        background: white;

        display: flex;
        justify-content: center;
        align-items: center;
    }

    .card-back img {
        width: 70%;
    }
</style>
