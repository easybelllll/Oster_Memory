---
const { img } = Astro.props;
---

<div class="card" data-value={img}>
    <div class="card-inner">
        <div class="card-front"></div>
        <div class="card-back">
            <img src={img} alt="memory card" />
        </div>
    </div>
</div>
<style>
.card {
    perspective: 900px;
    cursor: pointer;
}
.card-inner {
    position: relative;
    width: 100px;
    aspect-ratio: 1;
    transition: transform 0.6s;
    transform-style: preserve-3d;
}
.card.flipped .card-inner {
    transform: rotateY(180deg);
}
.card-front{
    position: absolute;
    width: 100%;
    height: 100%;
    background: #e98989;
    border-radius: 16px;
    backface-visibility: hidden;
}

/* Vorderseite der Karte */
.card-front {
    position: absolute;
    width: 100%;
    height: 100%;
    background: #e98989;
    border-radius: 16px;
    backface-visibility: hidden;
}
/* Rückseite der Karte */
.card-back {
    position: absolute;
    width: 100%;
    height: 100%;
    transform: rotateY(180deg);
    border-radius: 16px;
    background: white;
    backface-visibility: hidden;

    display: flex;
    justify-content: center;
    align-items: center;
}
.card-back img {
    width: 70%;
}
</style>