---
import Popup from "../components/Popup.astro";
import Button from "../components/Button.astro";
import DekoImg from "../../public/Dekoration/gras.png";
import { Image } from "astro:assets";
---
<html>
<head>
    <script src="/global.js" is:inline></script>
</head>

<div id="leaderboard" class="page">
    <Popup>
        <h2>Rangliste</h2>
        <table id="leaderboardTable">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Zeit (s)</th>
                    <th>Züge</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
        <br />
        <Button class="btn-outline-pink" onclick="showPage('leaderboardSelect')" text="Andere Rangliste wählen"></Button>
    </Popup>
    <Image src={DekoImg} class="bottom-grass" alt="decoration"/>
</div>
</html>
<style>
    .page {
        display: none;
        min-height: 100vh;
        justify-content: center;
        align-items: center;
    }
    .page.active {
        display: flex;
    }

    #leaderboardTable {
        border-collapse: separate;
        border-spacing: 10px;
        width: fit-content;
        margin: 20px auto;
    }
    #leaderboardTable thead th {
        background: #e98989;
        color: white;
        padding: 10px 20px;
        border-radius: 20px;
        font-weight: bold;
        text-align: center;
        min-width: 80px;
    }
    #leaderboardTable tbody td {
        text-align: center;
        padding: 8px 12px;
        font-weight: bold;
    }
    .bottom-grass {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: auto;
        pointer-events: none;
        object-fit: cover;
    }
</style>