---
import Layout from "../layout/layout.astro";
import Popup from "../components/Popup.astro";
import LinkButton from "../components/LinkButton.astro";
import "../../public/global.css";

import DekoImg from "../../public/Dekoration/gras.png";
import { Image } from "astro:assets";
---

<Layout>
    <div class="end-page">
        <Popup>
            <h2>GLÜCKWUNSCH! 🎉</h2>

            <p>Zeit: <span id="time-display">0</span> Sekunden</p>
            <p>Züge: <span id="moves-display">0</span></p>

            <div class="button-wrap">
                <LinkButton href="/" text="Erneut spielen" />
                <LinkButton
                    href="/login"
                    text="In Rangliste speichern"
                    outline
                />
            </div>
        </Popup>

        <Image src={DekoImg} alt="Osterdekoration" class="bottom-decoration" />
    </div>
</Layout>

<script is:inline>
    // Werte aus URL holen
    const params = new URLSearchParams(window.location.search);
    const time = params.get("time") ?? 0;
    const moves = params.get("moves") ?? 0;

    // Werte ins DOM schreiben
    document.getElementById("time-display").textContent = time;
    document.getElementById("moves-display").textContent = moves;
</script>

<style>
    .end-page {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        width: 100vw;
        position: relative;
    }

    .button-wrap {
        display: flex;
        gap: 12px;
        margin-top: 20px;
    }
</style>
