---
import Layout from "../layout/layout.astro";
import Board from "../components/Board.astro";
import Sidebar from "../components/Sidebar.astro";
import { undefined } from "astro:schema";

const cardsParam = Number(Astro.url.searchParams.get("cards"));
const size = [12, 16, 24].includes(cardsParam) ? cardsParam : 16;

// Sidebar links
const sidebarLinks = [{ text: "Beenden", href: `/` }];
---

<Layout>
    <div class="game-page">
        <Sidebar links={sidebarLinks} />
        <Board size={size} />
    </div>
</Layout>

<style>
    .game-page {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        min-height: 100vh;
        width: 100vw;
        background: white;
    }
</style>
