---
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <title>{title || "Oster Memory"}</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f8e88c;
      text-align: center;
    }

    .page {
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      flex-direction: column;
      position: relative;
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>

